# ─────────────────────────────────────────────────────────────
# Timeless Hadith — ingestion secrets
# Copy this file to `.env` in the same folder, then fill in values.
# NEVER commit .env to git. .gitignore already excludes it.
# ─────────────────────────────────────────────────────────────

# Supabase project URL (same one the live site uses)
SUPABASE_URL=https://dwcsledifvnyrunxejzd.supabase.co

# Supabase SERVICE ROLE key — NOT the anon key.
# Find it at: Supabase dashboard → Project Settings → API → Project API keys → service_role
# This key bypasses Row Level Security. Keep it secret. Never put it in frontend code.
SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here

# OpenAI API key — used for generating embeddings
# Find it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=paste-your-openai-key-here

# Which embedding model to use. Do not change unless you know what you are doing.
# text-embedding-3-small = 1536 dimensions, matches the vector(1536) column in document_chunks.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
