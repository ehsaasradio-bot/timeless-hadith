# ─────────────────────────────────────────────────────────────
# Worker secrets reference (NOT used at runtime).
#
# For Cloudflare Workers, secrets are NOT stored in a .env file.
# They are uploaded to Cloudflare via the wrangler CLI:
#
#   wrangler secret put SUPABASE_URL
#   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#   wrangler secret put OPENAI_API_KEY
#
# This file just documents which secrets must be set.
# ─────────────────────────────────────────────────────────────

SUPABASE_URL=https://dwcsledifvnyrunxejzd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here
OPENAI_API_KEY=paste-your-openai-key-here
