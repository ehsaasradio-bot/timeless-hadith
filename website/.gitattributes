# Force LF line endings for all text files across all platforms
* text=auto eol=lf

# Explicitly declare text files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.txt  text eol=lf
*.xml  text eol=lf

# Binary files — do not modify line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.docx binary
*.pdf  binary
*.zip  binary
