# Timeless Hadith — Security Headers
# Cloudflare Pages (auto-applied), Netlify-compatible
# Last updated: 2026-04-10 — H-02 CORS hardened, M-01 CSP tightened, M-06 cache TTLs extended

# ── Global rules (all public pages) ──────────────────────────────────────────
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  # H-02: CORS restricted to same origin only — no wildcard on public pages
  Access-Control-Allow-Origin: https://timelesshadith.com
  # M-01: CSP hardened — removed unsafe-inline from script-src
  # Nonces are injected per-request for any remaining inline scripts
  Content-Security-Policy: default-src 'self'; script-src 'self' https://accounts.google.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://dwcsledifvnyrunxejzd.supabase.co https://cloudflareinsights.com https://api.openai.com;

# ── HTML pages — short cache (content can change) ────────────────────────────
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# ── JavaScript — long cache (M-06: extended from 4hrs to 1yr) ────────────────
/js/*.js
  Cache-Control: public, max-age=31536000, immutable

# ── CSS — long cache ──────────────────────────────────────────────────────────
/css/*.css
  Cache-Control: public, max-age=31536000, immutable

# ── Images — long cache (already correct) ─────────────────────────────────────
/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

# ── Manifest + Service Worker — short cache ───────────────────────────────────
/manifest.json
  Cache-Control: public, max-age=86400

/sw.js
  Cache-Control: no-cache

# ── Admin paths — CORS completely blocked, no-index ───────────────────────────
/cms.html
  Access-Control-Allow-Origin: https://timelesshadith.com
  X-Robots-Tag: noindex, nofollow

/cms-login.html
  Access-Control-Allow-Origin: https://timelesshadith.com
  X-Robots-Tag: noindex, nofollow

/admin.html
  Access-Control-Allow-Origin: https://timelesshadith.com
  X-Robots-Tag: noindex, nofollow

/admin-backup.html
  Access-Control-Allow-Origin: https://timelesshadith.com
  X-Robots-Tag: noindex, nofollow

# ── API routes — CORS restricted to own origin ────────────────────────────────
/api/*
  Access-Control-Allow-Origin: https://timelesshadith.com
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
