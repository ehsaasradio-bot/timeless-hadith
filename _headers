# Timeless Hadith — Security Headers
# Compatible with Netlify, Cloudflare Pages, and Vercel (rename to vercel.json for Vercel)
# For Apache (.htaccess) see the commented block at the bottom.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  Cache-Control: public, max-age=3600
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://static.cloudflareinsights.com; worker-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://dwcsledifvnyrunxejzd.supabase.co https://timeless-hadith-worker.ehsaasradio.workers.dev https://cloudflareinsights.com; manifest-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';

/index.html
  Cache-Control: public, max-age=3600, must-revalidate

/category.html
  Cache-Control: public, max-age=3600, must-revalidate

/admin.html
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache, must-revalidate
  X-Frame-Options: DENY

/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=86400

/*.js
  Cache-Control: public, max-age=86400

/*.json
  Cache-Control: public, max-age=86400

# ── Apache .htaccess equivalent ──────────────────────────────
# <IfModule mod_headers.c>
#   Header always set X-Frame-Options "DENY"
#   Header always set X-Content-Type-Options "nosniff"
#   Header always set Referrer-Policy "strict-origin-when-cross-origin"
#   Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
#   Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
#   Header always set X-XSS-Protection "1; mode=block"
# </IfModule>
